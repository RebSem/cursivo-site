---
import UseCaseIndexPage from "../../components/UseCaseIndexPage.astro";
import { getLocalizedUseCases } from "../../data/content";
import { getHomeContent } from "../../data/site";
import {
	getUseCaseLocaleLinks,
	getUseCaseNav,
	useCaseIndexCopyByLocale,
	getUseCaseEntryPath,
} from "../../data/use-cases";

const locale = "en" as const;
const home = getHomeContent(locale);
const copy = useCaseIndexCopyByLocale[locale];
const entries = await getLocalizedUseCases(locale);
const items = entries.map((entry) => ({
	title: entry.data.title,
	description: entry.data.description,
	href: getUseCaseEntryPath(locale, entry.data.translationKey),
	industry: entry.data.industry,
	audience: entry.data.audience,
}));
---

<UseCaseIndexPage
	currentLocale={locale}
	brandMeta={home.brandMeta}
	navItems={getUseCaseNav(locale)}
	localeLinks={getUseCaseLocaleLinks()}
	footerTitle={home.footerTitle}
	footerCopy={home.footerCopy}
	footerMetaLabel={home.footerMetaLabel}
	footerMetaValue={home.footerMetaValue}
	copy={copy}
	items={items}
/>
