---
import PublishingIndexPage from "../../../components/PublishingIndexPage.astro";
import { getLocalizedEntries, formatPublishDate } from "../../../data/content";
import { publishIndexCopyByLocale, getCollectionLocaleLinks, getPublishingNav } from "../../../data/publishing";
import { getHomeContent } from "../../../data/site";

const locale = "ar" as const;
const home = getHomeContent(locale);
const copy = publishIndexCopyByLocale[locale].changelog;
const entries = await getLocalizedEntries("changelog", locale);
const items = entries.map((entry) => ({
	title: entry.data.title,
	description: entry.data.description,
	href: `/ar/changelog/${entry.data.translationKey}/`,
	meta: `${entry.data.version} · ${formatPublishDate(entry.data.publishedAt, locale)}`,
	status: "Release",
}));
---

<PublishingIndexPage
	collection="changelog"
	currentLocale={locale}
	brandMeta={home.brandMeta}
	navItems={getPublishingNav(locale)}
	localeLinks={getCollectionLocaleLinks("changelog")}
	footerTitle={home.footerTitle}
	footerCopy={home.footerCopy}
	footerMetaLabel={home.footerMetaLabel}
	footerMetaValue={home.footerMetaValue}
	copy={copy}
	items={items}
/>
