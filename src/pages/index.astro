---
import HomePage from "../components/HomePage.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { englishSiteChrome } from "../data/landing";
---

<BaseLayout
	title="Cursivo | Car rental CRM for Dubai operators"
	description="Cursivo is an AI-powered car rental CRM for Dubai teams that replaces scattered Telegram and WhatsApp chats with structured lead intake, quotes, reservations, and branch-ready tasks."
	lang="en"
	brandMeta={englishSiteChrome.brandMeta}
	navItems={englishSiteChrome.navItems}
	localeLinks={englishSiteChrome.localeLinks}
	currentLocale={englishSiteChrome.currentLocale}
	footerTitle={englishSiteChrome.footerTitle}
	footerCopy={englishSiteChrome.footerCopy}
	footerMetaLabel={englishSiteChrome.footerMetaLabel}
	footerMetaValue={englishSiteChrome.footerMetaValue}
	canonicalPath="/"
	ctaHref="#contact"
>
	<div class="site-container">
		<HomePage />
	</div>
</BaseLayout>
