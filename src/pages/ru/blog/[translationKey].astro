---
import { render } from "astro:content";
import PublishingEntryPage from "../../../components/PublishingEntryPage.astro";
import {
	buildLocaleLinksForEntry,
	formatPublishDate,
	getEntryByTranslationKey,
	getEntryTranslations,
	getLocalizedEntries,
} from "../../../data/content";
import {
	getCollectionIndexPath,
	publishEntryCopyByLocale,
	publishIndexCopyByLocale,
	getPublishingNav,
} from "../../../data/publishing";
import { getHomeContent } from "../../../data/site";

export async function getStaticPaths() {
	const entries = await getLocalizedEntries("blog", "ru");
	return entries.map((entry) => ({
		params: { translationKey: entry.data.translationKey },
	}));
}

const locale = "ru" as const;
const { translationKey } = Astro.params;
const entry = translationKey ? await getEntryByTranslationKey("blog", locale, translationKey) : null;

if (!entry) {
	throw new Error("Blog entry not found");
}

const translations = await getEntryTranslations("blog", entry.data.translationKey);
const localeLinks = buildLocaleLinksForEntry("blog", translations);
const { Content } = await render(entry);
const home = getHomeContent(locale);
---

<PublishingEntryPage
	collection="blog"
	currentLocale={locale}
	brandMeta={home.brandMeta}
	navItems={getPublishingNav(locale)}
	localeLinks={localeLinks}
	footerTitle={home.footerTitle}
	footerCopy={home.footerCopy}
	footerMetaLabel={home.footerMetaLabel}
	footerMetaValue={home.footerMetaValue}
	entryMeta={{
		title: entry.data.title,
		description: entry.data.description,
		publishedAt: entry.data.publishedAt,
		category: entry.data.category,
		translationKey: entry.data.translationKey,
	}}
	copy={publishEntryCopyByLocale[locale]}
	indexCopy={publishIndexCopyByLocale[locale].blog}
	backHref={getCollectionIndexPath("blog", locale)}
	entryPath={`/ru/blog/${entry.data.translationKey}/`}
	Content={Content}
	formattedDate={formatPublishDate(entry.data.publishedAt, locale)}
/>
