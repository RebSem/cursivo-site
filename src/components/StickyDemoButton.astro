---
interface Props {
	href: string;
	thresholdSelector: string;
}

const { href, thresholdSelector } = Astro.props;
---

<a class="sticky-demo-button" data-sticky-demo-button data-threshold-selector={thresholdSelector} href={href}>
	Request demo
</a>

<style>
	.sticky-demo-button {
		position: fixed;
		right: var(--page-gutter);
		bottom: var(--page-gutter);
		z-index: 40;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.9rem 1.5rem;
		border-radius: var(--radius-pill);
		background: linear-gradient(165deg, #ff6b35, #c96a3a) !important;
		color: #ffffff !important;
		text-decoration: none;
		font-weight: 800;
		font-size: 1rem;
		border: 1px solid rgba(255, 255, 255, 0.2) !important;
		box-shadow: 0 6px 18px rgba(255, 107, 53, 0.3) !important;
		transform: translate3d(0, 150%, 0);
		opacity: 0;
		pointer-events: none;
		transition:
			transform 400ms cubic-bezier(0.34, 1.56, 0.64, 1),
			opacity 250ms ease,
			filter 200ms ease,
			box-shadow 250ms ease;
		will-change: transform;
	}

	.sticky-demo-button.is-visible {
		transform: translate3d(0, 0, 0);
		opacity: 1;
		pointer-events: auto;
	}

	.sticky-demo-button:hover {
		filter: brightness(1.1);
		transform: scale(1.05) translateY(-2px);
		box-shadow: 0 12px 28px rgba(255, 107, 53, 0.45) !important;
	}

	.sticky-demo-button:active {
		transform: scale(0.96);
	}

	@media (max-width: 640px) {
		.sticky-demo-button {
			left: var(--page-gutter);
			right: var(--page-gutter);
		}
	}
</style>

<script is:inline>
	(() => {
		const button = document.querySelector("[data-sticky-demo-button]");
		if (!(button instanceof HTMLElement)) return;

		const selector = button.dataset.thresholdSelector;
		const thresholdNode = selector ? document.querySelector(selector) : null;
		const toggle = (visible) => button.classList.toggle("is-visible", visible);

		if (!(thresholdNode instanceof HTMLElement) || !("IntersectionObserver" in window)) {
			const sync = () => toggle(window.scrollY > window.innerHeight * 0.6);
			sync();
			window.addEventListener("scroll", sync, { passive: true });
			return;
		}

		const observer = new IntersectionObserver(
			(entries) => {
				const entry = entries[0];
				toggle(!entry.isIntersecting);
			},
			{ threshold: 0.15 },
		);

		observer.observe(thresholdNode);
	})();
</script>
