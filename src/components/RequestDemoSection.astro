---
interface Props {
	id?: string;
	eyebrow?: string;
	title?: string;
	intro?: string;
}

const {
	id = "contact",
	eyebrow = "Contact",
	title = "Ready to see it in action?",
	intro = "Talk directly with the CEO. We'll show you how Cursivo handles lead intake, quote prep, and manager follow-up without the fluff.",
} = Astro.props;
---

<section class="request-demo section-card" id={id} data-reveal="soft">
	<div class="request-demo-copy">
		<p class="type-label request-demo-eyebrow">{eyebrow}</p>
		<h2 class="type-h2">{title}</h2>
		<p class="type-body-lg text-muted">{intro}</p>
		<div class="request-demo-points">
			<span>Dubai rental workflows</span>
			<span>WhatsApp, Site, Telegram and Instagram</span>
			<span>Live operator handoff</span>
		</div>
	</div>

	<div class="contact-links-grid">
		<a href="https://t.me/Michael_Semenov" target="_blank" rel="noopener noreferrer" class="contact-link-card">
			<div class="contact-link-icon telegram">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M22 2L11 13"></path>
					<path d="M22 2L15 22L11 13L2 9L22 2Z"></path>
				</svg>
			</div>
			<div class="contact-link-text">
				<strong>Telegram</strong>
				<span>Chat with CEO</span>
			</div>
		</a>

		<a href="https://wa.me/79822306019" target="_blank" rel="noopener noreferrer" class="contact-link-card">
			<div class="contact-link-icon whatsapp">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path>
				</svg>
			</div>
			<div class="contact-link-text">
				<strong>WhatsApp</strong>
				<span>Direct message</span>
			</div>
		</a>

		<a href="https://www.linkedin.com/in/mikhail-semenovv/" target="_blank" rel="noopener noreferrer" class="contact-link-card">
			<div class="contact-link-icon linkedin">
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
					<rect x="2" y="9" width="4" height="12"></rect>
					<circle cx="4" cy="4" r="2"></circle>
				</svg>
			</div>
			<div class="contact-link-text">
				<strong>LinkedIn</strong>
				<span>Connect on LinkedIn</span>
			</div>
		</a>
	</div>
</section>

<style>
	.request-demo {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(18rem, 32rem);
		gap: clamp(1.25rem, 2.5vw, 3rem);
		align-items: start;
	}

	.request-demo-eyebrow {
		margin-bottom: var(--space-3);
		color: var(--color-terracotta);
	}

	.request-demo-copy h2 {
		margin-bottom: var(--space-4);
	}

	.request-demo-copy p {
		margin-bottom: 0;
	}

	.request-demo-points {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem;
		margin-top: var(--space-5);
	}

	.request-demo-points span {
		padding: 0.5rem 0.75rem;
		border: 1px solid var(--color-border-sand);
		border-radius: var(--radius-pill);
		background: var(--surface-card);
		font-family: var(--font-mono);
		font-size: var(--text-label);
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--color-slate);
	}

	.contact-links-grid {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		padding-top: 0.5rem;
	}

	.contact-link-card {
		display: flex;
		align-items: center;
		gap: 1.15rem;
		padding: 0.75rem 1.1rem;
		border: 1px solid var(--color-border-sand);
		border-radius: var(--radius-xl);
		background: linear-gradient(180deg, var(--surface-card), var(--surface-raised));
		box-shadow: var(--shadow-card);
		text-decoration: none;
		transition:
			transform var(--motion-fast) cubic-bezier(0.175, 0.885, 0.32, 1.275),
			box-shadow var(--motion-fast) ease,
			border-color var(--motion-fast) ease;
	}

	.contact-link-card:hover {
		transform: translateY(-3px) scale(1.01);
		box-shadow: 0 16px 32px rgba(20, 32, 51, 0.08);
		border-color: rgba(201, 106, 58, 0.4);
	}

	.contact-link-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.2rem;
		height: 2.2rem;
		border-radius: 50%;
		background: var(--color-accent-soft);
		color: var(--color-terracotta-active);
		transition:
			background var(--motion-fast) ease,
			color var(--motion-fast) ease,
			transform var(--motion-spring);
	}

	.contact-link-card:hover .contact-link-icon {
		transform: scale(1.1) rotate(-5deg);
	}

	.contact-link-icon.telegram {
		background: rgba(40, 168, 233, 0.1);
		color: #28a8e9;
	}

	.contact-link-card:hover .contact-link-icon.telegram {
		background: rgba(40, 168, 233, 0.18);
	}

	.contact-link-icon.whatsapp {
		background: rgba(37, 211, 102, 0.1);
		color: #25d366;
	}

	.contact-link-card:hover .contact-link-icon.whatsapp {
		background: rgba(37, 211, 102, 0.18);
	}

	.contact-link-icon.linkedin {
		background: rgba(10, 102, 194, 0.1);
		color: #0a66c2;
	}

	.contact-link-card:hover .contact-link-icon.linkedin {
		background: rgba(10, 102, 194, 0.18);
	}

	.contact-link-icon svg {
		width: 1.1rem;
		height: 1.1rem;
	}

	.contact-link-text {
		display: grid;
		gap: 0.15rem;
	}

	.contact-link-text strong {
		color: var(--color-ink);
		font-family: var(--font-display);
		font-weight: 700;
		font-size: 1.15rem;
		line-height: 1.1;
		transition: color var(--motion-fast) ease;
	}

	.contact-link-card:hover .contact-link-text strong {
		color: var(--color-terracotta-active);
	}

	.contact-link-text span {
		color: var(--color-slate);
		font-size: 0.95rem;
	}

	@media (max-width: 760px) {
		.request-demo {
			grid-template-columns: 1fr;
		}
	}
</style>