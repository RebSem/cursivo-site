---
interface SetupStep {
	label: string;
	title: string;
	meta: string;
	tone: "terracotta" | "navy" | "success" | "warning";
}

interface WorkspaceCard {
	title: string;
	meta: string;
}

interface Props {
	eyebrow?: string;
	title: string;
	intro: string;
	sourceLabel: string;
	sourceTitle: string;
	sourceMeta: string;
	steps: SetupStep[];
	workspaceLabel: string;
	workspaceTitle: string;
	workspaceMeta: string;
	workspaceCards: WorkspaceCard[];
}

const {
	eyebrow,
	title,
	intro,
	sourceLabel,
	sourceTitle,
	sourceMeta,
	steps,
	workspaceLabel,
	workspaceTitle,
	workspaceMeta,
	workspaceCards,
} = Astro.props;
---

<section class="setup-section">
	<header class="setup-head">
		{eyebrow && <p class="setup-eyebrow type-label">{eyebrow}</p>}
		<h2 class="type-h2">{title}</h2>
		<p class="setup-intro text-muted">{intro}</p>
	</header>

	<div class="setup-grid">
		<article class="setup-source-card">
			<p class="setup-card-label type-label">{sourceLabel}</p>
			<div class="setup-sheet">
				<div class="setup-sheet-top">
					<span class="setup-sheet-dot"></span>
					<span class="setup-sheet-dot"></span>
					<span class="setup-sheet-dot"></span>
				</div>
				<div class="setup-sheet-body">
					<h3>{sourceTitle}</h3>
					<p class="text-muted">{sourceMeta}</p>
					<ul class="setup-sheet-rows">
						<li>branch_name | fleet_group | language</li>
						<li>daily_rate | deposit | class</li>
						<li>pickup_rules | manager_owner | city</li>
					</ul>
				</div>
			</div>
		</article>

		<div class="setup-flow">
			<div class="setup-rail" aria-hidden="true"></div>
			{steps.map((step, index) => (
				<article class={`setup-step tone-${step.tone}`} style={`--setup-index:${index};`}>
					<p class="setup-card-label type-label">{step.label}</p>
					<h3>{step.title}</h3>
					<p class="text-muted">{step.meta}</p>
				</article>
			))}
		</div>

		<article class="setup-workspace-card">
			<p class="setup-card-label type-label">{workspaceLabel}</p>
			<h3>{workspaceTitle}</h3>
			<p class="text-muted">{workspaceMeta}</p>
			<div class="setup-workspace-grid">
				{workspaceCards.map((card) => (
					<div class="setup-workspace-tile">
						<h4>{card.title}</h4>
						<p class="text-muted">{card.meta}</p>
					</div>
				))}
			</div>
		</article>
	</div>
</section>

<style>
	.setup-section {
		background: var(--surface-raised);
		border: 1px solid var(--color-border-sand);
		border-radius: var(--radius-xl);
		padding: var(--space-7);
		box-shadow: var(--shadow-soft);
	}

	.setup-head {
		display: grid;
		gap: 0.8rem;
		max-width: 46rem;
	}

	.setup-eyebrow {
		color: var(--color-terracotta);
	}

	.setup-intro {
		margin-bottom: 0;
	}

	.setup-grid {
		display: grid;
		grid-template-columns: minmax(17rem, 0.95fr) minmax(0, 1.3fr) minmax(18rem, 1fr);
		gap: var(--space-4);
		margin-top: var(--space-5);
	}

	.setup-source-card,
	.setup-workspace-card {
		display: grid;
		align-content: start;
		gap: 1rem;
		padding: 1.1rem;
		border-radius: var(--radius-xl);
		border: 1px solid rgba(113, 88, 62, 0.12);
		background:
			linear-gradient(180deg, rgba(255, 253, 249, 0.92), rgba(255, 253, 249, 0.82)),
			var(--surface-card);
		box-shadow: var(--shadow-card);
	}

	.setup-card-label {
		color: var(--color-slate);
	}

	.setup-sheet {
		overflow: hidden;
		border-radius: 1.1rem;
		border: 1px solid rgba(113, 88, 62, 0.12);
		background: rgba(255, 253, 249, 0.92);
	}

	.setup-sheet-top {
		display: flex;
		gap: 0.35rem;
		padding: 0.7rem 0.8rem;
		border-bottom: 1px solid rgba(113, 88, 62, 0.08);
		background: rgba(20, 32, 51, 0.04);
	}

	.setup-sheet-dot {
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 999px;
		background: rgba(201, 106, 58, 0.32);
	}

	.setup-sheet-body {
		padding: 1rem;
	}

	.setup-sheet-body h3,
	.setup-step h3,
	.setup-workspace-card h3,
	.setup-workspace-tile h4 {
		font-size: var(--text-h3);
	}

	.setup-sheet-body p,
	.setup-step p,
	.setup-workspace-card p,
	.setup-workspace-tile p {
		margin-bottom: 0;
		font-size: var(--text-small);
		line-height: 1.65;
	}

	.setup-sheet-rows {
		display: grid;
		gap: 0.55rem;
		padding: 0;
		margin: 1rem 0 0;
		list-style: none;
		font-family: var(--font-mono);
		font-size: var(--text-label);
		letter-spacing: 0.04em;
		color: var(--color-slate);
	}

	.setup-sheet-rows li {
		padding: 0.65rem 0.75rem;
		border-radius: 0.85rem;
		background: rgba(20, 32, 51, 0.04);
	}

	.setup-flow {
		position: relative;
		display: grid;
		gap: 0.9rem;
		padding: 0.35rem 0;
	}

	.setup-rail {
		position: absolute;
		inset: 1.4rem auto 1.4rem 1rem;
		width: 1px;
		background:
			repeating-linear-gradient(
				180deg,
				rgba(201, 106, 58, 0.5) 0,
				rgba(201, 106, 58, 0.5) 12px,
				transparent 12px,
				transparent 22px
			);
	}

	.setup-step {
		position: relative;
		margin-left: 1rem;
		padding: 1rem 1rem 1rem 1.2rem;
		border-radius: var(--radius-lg);
		border: 1px solid rgba(113, 88, 62, 0.12);
		background: rgba(255, 253, 249, 0.9);
		box-shadow: var(--shadow-card);
	}

	.setup-step::before {
		content: "";
		position: absolute;
		left: -1rem;
		top: 1.25rem;
		width: 1rem;
		height: 1px;
		background: rgba(201, 106, 58, 0.4);
	}

	.setup-workspace-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.8rem;
	}

	.setup-workspace-tile {
		padding: 0.9rem;
		border-radius: 1rem;
		border: 1px solid rgba(113, 88, 62, 0.1);
		background: rgba(255, 253, 249, 0.76);
	}

	.setup-workspace-tile h4 {
		margin: 0 0 0.35rem;
		line-height: 1.15;
	}

	.tone-terracotta {
		background:
			linear-gradient(180deg, rgba(201, 106, 58, 0.08), rgba(255, 253, 249, 0.88)),
			var(--surface-card);
	}

	.tone-navy {
		background:
			linear-gradient(180deg, rgba(40, 71, 102, 0.08), rgba(255, 253, 249, 0.88)),
			var(--surface-card);
	}

	.tone-success {
		background:
			linear-gradient(180deg, rgba(47, 138, 98, 0.08), rgba(255, 253, 249, 0.88)),
			var(--surface-card);
	}

	.tone-warning {
		background:
			linear-gradient(180deg, rgba(173, 106, 39, 0.08), rgba(255, 253, 249, 0.88)),
			var(--surface-card);
	}

	@media (max-width: 1024px) {
		.setup-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.setup-section {
			padding: 1.375rem;
		}

		.setup-workspace-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
