---
import type { Locale, LocaleLink, NavItem } from "../data/site";

interface Props {
	brandMeta: string;
	navItems: NavItem[];
	localeLinks: LocaleLink[];
	currentLocale: Locale;
	ctaHref?: string;
}

const { navItems, localeLinks, currentLocale, ctaHref } = Astro.props;
const currentLocaleHome = localeLinks.find((item) => item.code === currentLocale)?.href ?? "/";
const requestDemoHref = ctaHref ?? `${currentLocaleHome}#contact`;
---

<header class="site-header" data-site-header>
	<div class="site-container site-header-inner">
		<div class="header-left">
			<a class="site-brand" href={currentLocaleHome}>
				<span class="site-brand-name">Cursivo</span>
			</a>
		</div>

		<nav class="site-nav" aria-label="Primary">
			{navItems.map((item) => (
				<a href={item.href}>{item.label}</a>
			))}
		</nav>

		<div class="header-right">
			<a class="site-header-cta desktop-cta" href={requestDemoHref}>Request demo</a>
			
			<button class="menu-toggle" aria-label="Toggle menu" data-menu-toggle>
				<span class="burger-line line-top"></span>
				<span class="burger-line line-bottom"></span>
			</button>
		</div>

		<div class="mobile-menu-portal" data-mobile-menu>
			<nav class="mobile-nav">
				{navItems.map((item) => (
					<a href={item.href} class="mobile-nav-link">{item.label}</a>
				))}
				<a class="site-header-cta mobile-cta" href={requestDemoHref}>Request demo</a>
			</nav>
		</div>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0.85rem; /* Fixed top position to prevent scroll jitter */
		z-index: 100;
		padding: 0;
		display: flex;
		justify-content: center;
		pointer-events: none; /* Let clicks pass through outer container */
	}

	.site-header-inner {
		pointer-events: auto; /* Re-enable clicks inside the capsule */
		position: relative;
		display: flex;
		justify-content: space-between;
		align-items: center;
		width: 100%;
		max-width: var(--shell-width);
		
		/* Unscrolled state: Transparent, pushed down slightly */
		padding: 0.85rem 0;
		background: transparent;
		border: 1px solid transparent;
		border-radius: 999px;
		box-shadow: none;
		backdrop-filter: blur(0px) saturate(100%);
		-webkit-backdrop-filter: blur(0px) saturate(100%);
		transform: translateY(0.4rem) translateZ(0); /* Hardware acceleration against jitter */
		
		transition: 
			max-width 500ms var(--motion-spring),
			padding 500ms var(--motion-spring),
			background 400ms ease,
			box-shadow 400ms ease,
			border-radius 500ms var(--motion-spring),
			border-color 400ms ease,
			backdrop-filter 400ms ease,
			transform 500ms var(--motion-spring);
		
		will-change: max-width, padding, transform, background;
	}

	/* Scrolled Desktop State (Floating Capsule) */
	.site-header.is-scrolled .site-header-inner {
		max-width: 820px;
		padding: 0.55rem 0.75rem 0.55rem 1.5rem;
		background: rgba(255, 253, 249, 0.82);
		border-color: rgba(113, 88, 62, 0.12);
		box-shadow: 
			0 20px 48px rgba(20, 32, 51, 0.08),
			inset 0 1px 0 rgba(255, 255, 255, 0.8);
		backdrop-filter: blur(40px) saturate(160%);
		-webkit-backdrop-filter: blur(40px) saturate(160%);
		transform: translateY(0) translateZ(0); /* Snaps to true sticky top */
	}

	.header-left { display: flex; align-items: center; }
	.header-right { display: flex; justify-content: flex-end; align-items: center; gap: 0.5rem; }

	.site-brand {
		text-decoration: none;
		transition: transform 300ms var(--motion-spring);
		display: inline-flex;
	}
	.site-brand:hover { transform: scale(1.03); }
	.site-brand:active { transform: scale(0.97); }

	.site-brand-name {
		font-family: var(--font-display);
		font-weight: 800;
		font-size: 1.45rem;
		letter-spacing: -0.03em;
		color: var(--color-ink);
		line-height: 1;
		transition: font-size 400ms ease;
	}

	/* Absolute centering for Nav links */
	.site-nav { 
		position: absolute;
		left: 50%;
		transform: translateX(-50%);
		display: flex; 
		align-items: center; 
		gap: 0.15rem; 
	}

	.site-nav a {
		position: relative;
		padding: 0.6rem 1rem;
		text-decoration: none;
		color: var(--color-slate);
		font-size: 0.95rem;
		font-weight: 500;
		transition: color 300ms ease, opacity 300ms ease, transform 300ms ease;
	}
	
	.site-nav a::after {
		content: ""; position: absolute; bottom: 0.35rem; left: 50%; width: 1.25rem; height: 1.5px;
		background: var(--color-terracotta); border-radius: 99px;
		transform: translateX(-50%) scaleX(0); opacity: 0;
		transition: transform 400ms var(--motion-spring), opacity 300ms ease;
	}
	
	.site-nav a:hover { color: var(--color-ink); }
	.site-nav a:hover::after { transform: translateX(-50%) scaleX(1); opacity: 1; }
	.site-nav:hover a:not(:hover) { opacity: 0.65; }

	/* Brand Color Button */
	.site-header-cta {
		display: inline-flex; align-items: center; justify-content: center;
		padding: 0.65rem 1.25rem; border-radius: 999px;
		background: linear-gradient(165deg, #ff6b35, #c96a3a);
		color: #ffffff !important; /* Force white text over brand color */
		text-decoration: none; font-weight: 700; font-size: 0.875rem;
		border: 1px solid rgba(255, 255, 255, 0.2);
		box-shadow: 
			0 4px 12px rgba(255, 107, 53, 0.25), 
			inset 0 1px 0 rgba(255, 255, 255, 0.2);
		transition: transform 450ms var(--motion-spring), filter 300ms ease, box-shadow 450ms var(--motion-spring);
		will-change: transform;
	}
	.site-header-cta:hover {
		filter: brightness(1.08);
		transform: scale(1.04) translateY(-1.5px);
		box-shadow: 
			0 10px 24px rgba(255, 107, 53, 0.4), 
			inset 0 1px 0 rgba(255, 255, 255, 0.3);
	}
	.site-header-cta:active { transform: scale(0.96) translateY(0); box-shadow: 0 4px 8px rgba(255, 107, 53, 0.2); }

	.menu-toggle {
		display: none;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		width: 2.6rem;
		height: 2.6rem;
		padding: 0;
		background: rgba(20, 32, 51, 0.05);
		border: none;
		border-radius: 50%;
		cursor: pointer;
		transition: background 200ms ease, transform 300ms var(--motion-spring);
	}
	.menu-toggle:hover { background: rgba(20, 32, 51, 0.08); }
	.menu-toggle:active { transform: scale(0.92); }

	.burger-line {
		width: 1.1rem;
		height: 1.5px;
		background: var(--color-ink);
		border-radius: 99px;
		transition: transform 400ms var(--motion-spring), opacity 300ms ease;
	}
	.line-top { margin-bottom: 4px; }

	.site-header.is-menu-open .line-top { transform: translateY(2.75px) rotate(45deg); }
	.site-header.is-menu-open .line-bottom { transform: translateY(-2.75px) rotate(-45deg); }

	.mobile-menu-portal {
		position: absolute;
		top: calc(100% + 0.65rem);
		left: 0;
		right: 0;
		padding: 0.75rem;
		background: rgba(255, 253, 249, 0.95);
		border: 1px solid rgba(113, 88, 62, 0.12);
		border-radius: 1.5rem;
		box-shadow: 0 24px 64px rgba(20, 32, 51, 0.12);
		backdrop-filter: blur(24px) saturate(140%);
		-webkit-backdrop-filter: blur(24px) saturate(140%);
		
		opacity: 0;
		visibility: hidden;
		transform: translateY(-10px) scale(0.98);
		transform-origin: top center;
		transition: 
			opacity 400ms ease,
			visibility 400ms ease,
			transform 500ms var(--motion-spring);
	}

	.site-header.is-menu-open .mobile-menu-portal {
		opacity: 1;
		visibility: visible;
		transform: translateY(0) scale(1);
	}

	.mobile-nav {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.mobile-nav-link {
		padding: 1rem 1.25rem;
		text-decoration: none;
		color: var(--color-ink);
		font-weight: 600;
		font-size: 1.125rem;
		border-radius: 1rem;
		transition: background 200ms ease, transform 200ms ease;
	}
	.mobile-nav-link:active {
		background: rgba(201, 106, 58, 0.06);
		transform: scale(0.98);
	}

	.mobile-cta { width: 100%; margin-top: 0.5rem; padding: 1.1rem; font-size: 1rem; }

	/* Nested Scroll State Adjustments */
	.site-header.is-scrolled .site-brand-name { font-size: 1.25rem; }
	.site-header.is-scrolled .site-nav a { padding: 0.45rem 0.9rem; font-size: 0.875rem; }
	.site-header.is-scrolled .site-nav a::after { bottom: 0.25rem; }
	.site-header.is-scrolled .site-header-cta { padding: 0.55rem 1.15rem; font-size: 0.825rem; }

	@media (max-width: 860px) {
		.site-header { 
			top: 0; 
		}
		
		.site-header-inner { 
			/* No absolute nav on mobile */
			display: grid;
			grid-template-columns: 1fr auto; 
			padding: 1rem 0; 
			transform: translateY(0) translateZ(0);
		}
		
		.site-nav, .desktop-cta { 
			display: none; 
		}
		
		.menu-toggle { 
			display: flex; 
		}
		
		/* Mobile Scrolled State: Full width solid bar */
		.site-header.is-scrolled .site-header-inner,
		.site-header.is-menu-open .site-header-inner {
			max-width: none;
			width: calc(100% + (var(--page-gutter) * 2));
			margin: 0 calc(var(--page-gutter) * -1);
			padding: 0.75rem var(--page-gutter);
			background: rgba(255, 253, 249, 0.88);
			border-color: transparent;
			border-bottom-color: rgba(113, 88, 62, 0.12);
			border-radius: 0;
			box-shadow: 0 8px 24px rgba(20, 32, 51, 0.06);
			transform: none;
			backdrop-filter: blur(24px) saturate(140%);
			-webkit-backdrop-filter: blur(24px) saturate(140%);
		}

		.site-header.is-menu-open .site-header-inner {
			background: rgba(255, 253, 249, 0.98);
			border-bottom-color: transparent;
			box-shadow: none;
		}
		
		.mobile-menu-portal {
			top: 100%;
			border-radius: 0 0 1.5rem 1.5rem;
			border-top: 1px solid rgba(113, 88, 62, 0.08);
			padding: 0.75rem var(--page-gutter) 1.5rem;
		}
	}
</style>

<script is:inline>
	(() => {
		const header = document.querySelector("[data-site-header]");
		const menuToggle = document.querySelector("[data-menu-toggle]");
		const mobileMenu = document.querySelector("[data-mobile-menu]");
		
		if (!(header instanceof HTMLElement) || !menuToggle) return;

		const syncState = () => {
			header.classList.toggle("is-scrolled", window.scrollY > 16);
		};

		const toggleMenu = () => {
			const isOpen = header.classList.toggle("is-menu-open");
			if (isOpen) {
				document.body.style.overflow = "hidden";
			} else {
				document.body.style.overflow = "";
			}
		};

		// Close menu when clicking links
		mobileMenu?.querySelectorAll("a").forEach(link => {
			link.addEventListener("click", () => {
				header.classList.remove("is-menu-open");
				document.body.style.overflow = "";
			});
		});

		menuToggle.addEventListener("click", toggleMenu);
		syncState();
		window.addEventListener("scroll", syncState, { passive: true });
	})();
</script>
