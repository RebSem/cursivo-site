---
import type { Locale, LocaleLink, NavItem } from "../data/site";

interface Props {
	brandMeta: string;
	navItems: NavItem[];
	localeLinks: LocaleLink[];
	currentLocale: Locale;
	ctaHref?: string;
}

const { brandMeta, navItems, localeLinks, currentLocale, ctaHref } = Astro.props;
const currentLocaleHome = localeLinks.find((item) => item.code === currentLocale)?.href ?? "/";
const requestDemoHref = ctaHref ?? `${currentLocaleHome}#contact`;
---

<header class="site-header" data-site-header>
	<div class="site-container site-header-inner">
		<a class="site-brand" href={currentLocaleHome}>
			<span class="site-brand-mark">C</span>
			<span class="site-brand-copy">
				<span class="site-brand-name">Cursivo</span>
				<span class="site-brand-meta type-label">{brandMeta}</span>
			</span>
		</a>

		<nav class="site-nav" aria-label="Primary">
			{navItems.map((item) => (
				<a href={item.href}>{item.label}</a>
			))}
		</nav>

		{/* 
		<nav class="locale-nav" aria-label="Locales">
			{localeLinks.map((item) => (
				<a class:list={["locale-link", item.code === currentLocale && "is-active"]} href={item.href}>
					{item.label}
				</a>
			))}
		</nav>
		*/}

		<a class="site-header-cta" href={requestDemoHref}>Request demo</a>
	</div>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0.7rem;
		z-index: 30;
		padding: 0.65rem 0 0;
		transition:
			top var(--motion-fast) ease,
			padding var(--motion-fast) ease;
	}

	.site-header-inner {
		position: relative;
		display: grid;
		grid-template-columns: auto minmax(0, 1fr) auto;
		align-items: center;
		gap: clamp(0.85rem, 1.8vw, 1.5rem);
		padding: 0.92rem clamp(0.95rem, 1.8vw, 1.3rem);
		border: 1px solid rgba(255, 253, 249, 0.55);
		border-radius: clamp(1.3rem, 2vw, 1.9rem);
		background:
			linear-gradient(180deg, rgba(255, 253, 249, 0.82), rgba(255, 253, 249, 0.64)),
			rgba(255, 253, 249, 0.34);
		box-shadow:
			0 14px 34px rgba(20, 32, 51, 0.08),
			inset 0 1px 0 rgba(255, 255, 255, 0.78);
		backdrop-filter: blur(22px) saturate(145%);
		-webkit-backdrop-filter: blur(22px) saturate(145%);
		overflow: hidden;
	}

	.site-header-inner::before,
	.site-header-inner::after {
		content: "";
		position: absolute;
		inset: auto;
		pointer-events: none;
	}

	.site-header-inner::before {
		left: 0;
		right: 0;
		top: 0;
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.88), transparent);
	}

	.site-header-inner::after {
		top: -3.6rem;
		right: -2rem;
		width: 11rem;
		height: 11rem;
		border-radius: 999px;
		background: radial-gradient(circle, rgba(255, 255, 255, 0.4), transparent 68%);
	}

	.site-header.is-scrolled {
		top: 0.35rem;
		padding-top: 0.35rem;
	}

	.site-brand {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		text-decoration: none;
		min-width: 0;
	}

	.site-brand-mark {
		display: inline-grid;
		place-items: center;
		width: 2.35rem;
		height: 2.35rem;
		border-radius: 18px;
		background: linear-gradient(145deg, var(--color-terracotta), var(--color-terracotta-active));
		color: var(--color-ivory);
		font-family: var(--font-display);
		font-weight: 700;
		box-shadow:
			0 10px 22px rgba(201, 106, 58, 0.24),
			inset 0 1px 0 rgba(255, 255, 255, 0.28);
	}

	.site-brand-copy {
		display: grid;
		gap: 0.1rem;
		min-width: 0;
	}

	.site-brand-name {
		font-weight: 700;
	}

	.site-brand-meta {
		color: var(--color-slate);
		letter-spacing: 0.22em;
	}

	.site-nav {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.35rem 0.4rem;
		min-width: 0;
	}

	.site-nav a {
		padding: 0.62rem 0.86rem;
		border-radius: var(--radius-pill);
		border: 1px solid transparent;
		text-decoration: none;
		color: var(--color-slate);
		white-space: nowrap;
		transition:
			border-color 160ms ease,
			background-color 160ms ease,
			color 160ms ease,
			transform 160ms ease,
			box-shadow 160ms ease;
	}

	.site-nav a:hover {
		background: rgba(255, 253, 249, 0.46);
		border-color: rgba(255, 255, 255, 0.44);
		color: var(--color-ink);
		transform: translateY(-1px);
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.62);
	}

	.locale-nav {
		display: inline-flex;
		align-items: center;
		gap: 0.45rem;
		flex-wrap: wrap;
		justify-content: flex-end;
	}

	.locale-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 2.65rem;
		padding: 0.55rem 0.7rem;
		border-radius: var(--radius-pill);
		border: 1px solid rgba(255, 255, 255, 0.38);
		background: rgba(255, 253, 249, 0.52);
		text-decoration: none;
		color: var(--color-slate);
		font-family: var(--font-mono);
		font-size: var(--text-label);
		backdrop-filter: blur(10px);
	}

	.locale-link.is-active {
		border-color: rgba(201, 106, 58, 0.28);
		background: rgba(201, 106, 58, 0.12);
		color: var(--color-terracotta-active);
	}

	.site-header-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.75rem 1.35rem;
		border-radius: var(--radius-pill);
		background: linear-gradient(165deg, #ff6b35, #c96a3a) !important;
		color: #ffffff !important;
		text-decoration: none;
		font-weight: 800;
		font-size: 0.95rem;
		white-space: nowrap;
		border: 1px solid rgba(255, 255, 255, 0.25) !important;
		box-shadow: 
			0 4px 12px rgba(255, 107, 53, 0.3),
			inset 0 1px 0 rgba(255, 255, 255, 0.2) !important;
		transition:
			transform 250ms cubic-bezier(0.175, 0.885, 0.32, 1.275),
			filter 200ms ease,
			box-shadow 250ms ease;
		will-change: transform;
	}

	.site-header-cta:hover {
		filter: brightness(1.1);
		transform: scale(1.05) translateY(-1px);
		box-shadow: 
			0 10px 24px rgba(255, 107, 53, 0.45),
			inset 0 1px 0 rgba(255, 255, 255, 0.3) !important;
	}

	.site-header-cta:active {
		transform: scale(0.98);
	}

	@media (max-width: 720px) {
		.site-header {
			padding-top: 0.75rem;
		}

		.site-header-inner {
			grid-template-columns: 1fr;
			align-items: flex-start;
		}

		.site-nav {
			width: 100%;
			justify-content: flex-start;
			flex-wrap: nowrap;
			overflow-x: auto;
			padding-bottom: 0.15rem;
			scrollbar-width: none;
		}

		.site-nav::-webkit-scrollbar {
			display: none;
		}

		.locale-nav {
			justify-content: flex-start;
		}

		.site-header-cta {
			width: 100%;
		}
	}
</style>

<script is:inline>
	(() => {
		const header = document.querySelector("[data-site-header]");
		if (!(header instanceof HTMLElement)) return;

		const syncState = () => {
			header.classList.toggle("is-scrolled", window.scrollY > 16);
		};

		syncState();
		window.addEventListener("scroll", syncState, { passive: true });
	})();
</script>
