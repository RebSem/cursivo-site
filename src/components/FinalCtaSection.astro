---
interface FinalCtaLink {
	label: string;
	href: string;
	tone: "primary" | "secondary" | "ghost";
	meta: string;
}

interface Props {
	eyebrow?: string;
	title: string;
	intro: string;
	links: FinalCtaLink[];
}

const { eyebrow, title, intro, links } = Astro.props;
const isExternalLink = (href: string) => href.startsWith("http://") || href.startsWith("https://");
---

<section class="final-cta-section" data-reveal="soft">
	<div class="final-cta-shell">
		<div class="final-cta-copy">
			{eyebrow && <p class="final-cta-eyebrow type-label">{eyebrow}</p>}
			<h2 class="type-h2">{title}</h2>
			<p class="final-cta-intro text-muted">{intro}</p>
		</div>
		<div class="final-cta-links">
			{links.map((link, index) => (
				<a
					class={`final-cta-link tone-${link.tone}`}
					href={link.href}
					target={isExternalLink(link.href) ? "_blank" : undefined}
					rel={isExternalLink(link.href) ? "noreferrer" : undefined}
					data-reveal="soft"
					style={`--reveal-delay:${120 + index * 80}ms;`}
				>
					<span class="final-cta-link-label">{link.label}</span>
					<span class="final-cta-link-meta">{link.meta}</span>
				</a>
			))}
		</div>
	</div>
</section>

<style>
	.final-cta-section {
		background:
			radial-gradient(circle at top right, rgba(201, 106, 58, 0.12), transparent 34%),
			linear-gradient(180deg, rgba(255, 253, 249, 0.96), rgba(255, 253, 249, 0.9));
		border: 1px solid var(--color-border-sand);
		border-radius: var(--radius-xl);
		padding: var(--space-7);
		box-shadow: var(--shadow-soft);
	}

	.final-cta-shell {
		display: grid;
		grid-template-columns: minmax(0, 1.1fr) minmax(18rem, 0.95fr);
		gap: var(--space-5);
		align-items: start;
	}

	.final-cta-copy {
		display: grid;
		gap: 0.85rem;
		max-width: 40rem;
	}

	.final-cta-eyebrow {
		color: var(--color-terracotta);
	}

	.final-cta-intro {
		margin-bottom: 0;
	}

	.final-cta-links {
		display: grid;
		gap: 0.85rem;
	}

	.final-cta-link {
		display: grid;
		gap: 0.45rem;
		padding: 1rem 1.05rem;
		border-radius: var(--radius-lg);
		border: 1px solid rgba(113, 88, 62, 0.12);
		text-decoration: none;
		box-shadow: var(--shadow-card);
		transition:
			transform 160ms ease,
			border-color 160ms ease,
			background-color 160ms ease;
	}

	.final-cta-link:hover {
		transform: translateY(-3px);
		border-color: rgba(201, 106, 58, 0.32);
	}

	.final-cta-link-label {
		font-weight: 700;
		line-height: 1.2;
	}

	.final-cta-link-meta {
		font-family: var(--font-mono);
		font-size: var(--text-label);
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: var(--color-slate);
	}

	.tone-primary {
		background: var(--color-terracotta);
		border-color: rgba(147, 72, 34, 0.18);
		color: var(--color-ivory);
	}

	.tone-primary .final-cta-link-meta {
		color: rgba(255, 253, 249, 0.82);
	}

	.tone-secondary {
		background:
			linear-gradient(180deg, rgba(40, 71, 102, 0.08), rgba(255, 253, 249, 0.94)),
			var(--surface-card);
		color: var(--color-ink);
	}

	.tone-ghost {
		background:
			linear-gradient(180deg, rgba(201, 106, 58, 0.06), rgba(255, 253, 249, 0.94)),
			var(--surface-card);
		color: var(--color-ink);
	}

	@media (max-width: 900px) {
		.final-cta-shell {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.final-cta-section {
			padding: 1.375rem;
		}
	}
</style>
