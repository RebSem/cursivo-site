---
interface Step {
	label: string;
	title: string;
	description: string;
	tone?: "terracotta" | "navy" | "success" | "warning";
}

interface Props {
	eyebrow: string;
	title: string;
	intro: string;
	steps: Step[];
}

const { eyebrow, title, intro, steps } = Astro.props;
---

<section class="loop-section section-card" data-reveal="soft">
	<header class="loop-header">
		<p class="loop-eyebrow type-label">{eyebrow}</p>
		<h2 class="type-h2">{title}</h2>
		<p class="loop-intro text-muted">{intro}</p>
	</header>

	<div class="loop-board" role="list" aria-label={title}>
		{steps.map((step, index) => (
			<div class="loop-step-wrap" role="listitem">
				<article
					class={`loop-step tone-${step.tone ?? "terracotta"}`}
					data-reveal="soft"
					style={`--reveal-delay:${120 + index * 90}ms;`}
				>
					<div class="loop-step-top">
						<span class="loop-index type-label">0{index + 1}</span>
						<span class="loop-tag type-label">{step.label}</span>
					</div>
					<h3>{step.title}</h3>
					<p class="text-muted">{step.description}</p>
				</article>
				{index < steps.length - 1 && <div class="loop-connector" aria-hidden="true"></div>}
			</div>
		))}
	</div>
</section>

<style>
	.loop-section {
		display: grid;
		gap: var(--space-5);
		overflow: hidden;
	}

	.loop-header {
		display: grid;
		gap: 0.75rem;
		max-width: 48rem;
	}

	.loop-eyebrow {
		color: var(--color-terracotta);
	}

	.loop-intro {
		margin-bottom: 0;
	}

	.loop-board {
		display: grid;
		gap: 0.9rem;
	}

	.loop-step-wrap {
		display: grid;
		gap: 0.9rem;
	}

	.loop-step {
		position: relative;
		padding: 1.1rem 1.15rem 1.15rem;
		border-radius: 22px;
		border: 1px solid rgba(113, 88, 62, 0.14);
		background: rgba(255, 253, 249, 0.92);
		box-shadow: var(--shadow-card);
		transition:
			transform var(--motion-fast) ease,
			box-shadow var(--motion-fast) ease;
	}

	.loop-step:hover {
		transform: translateY(-3px);
		box-shadow: 0 18px 40px rgba(20, 32, 51, 0.11);
	}

	.loop-step-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: 0.85rem;
	}

	.loop-index {
		color: var(--color-terracotta-active);
	}

	.loop-tag {
		color: var(--color-slate);
	}

	.loop-step h3 {
		font-size: var(--text-h3);
		margin-bottom: 0.55rem;
	}

	.loop-step p {
		margin-bottom: 0;
	}

	.loop-connector {
		width: calc(100% - 2rem);
		height: 1px;
		margin-inline-start: 1rem;
		background:
			repeating-linear-gradient(
				90deg,
				rgba(201, 106, 58, 0.5) 0,
				rgba(201, 106, 58, 0.5) 16px,
				transparent 16px,
				transparent 24px
			);
		transform: scaleX(0);
		transform-origin: left center;
		transition:
			transform var(--motion-slow) var(--motion-spring),
			opacity var(--motion-base) var(--motion-spring);
		opacity: 0.55;
	}

	.loop-section.is-visible .loop-connector {
		transform: scaleX(1);
		opacity: 1;
	}

	:global([dir="rtl"]) .loop-connector {
		transform-origin: right center;
	}

	.tone-terracotta {
		background:
			linear-gradient(180deg, rgba(201, 106, 58, 0.08), transparent 34%),
			rgba(255, 253, 249, 0.92);
	}

	.tone-navy {
		background:
			linear-gradient(180deg, rgba(40, 71, 102, 0.08), transparent 34%),
			rgba(255, 253, 249, 0.92);
	}

	.tone-warning {
		background:
			linear-gradient(180deg, rgba(173, 106, 39, 0.08), transparent 34%),
			rgba(255, 253, 249, 0.92);
	}

	.tone-success {
		background:
			linear-gradient(180deg, rgba(47, 138, 98, 0.08), transparent 34%),
			rgba(255, 253, 249, 0.92);
	}

	@media (min-width: 900px) {
		.loop-board {
			grid-template-columns: repeat(5, minmax(0, 1fr));
			align-items: start;
		}

		.loop-step-wrap {
			grid-column: span 1;
			gap: 0;
		}

		.loop-step {
			min-height: 14rem;
		}

		.loop-connector {
			position: relative;
			width: calc(100% + 1.1rem);
			margin: 0 0 0 calc(100% - 1rem);
			top: -7rem;
		}
	}

	@media (max-width: 640px) {
		.loop-step {
			padding: 1rem;
			border-radius: var(--radius-lg);
		}

		.loop-step-top {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.45rem;
		}
	}
</style>
