---
import LocaleSwitcher from "./LocaleSwitcher.astro";
import { footerLinkGroupsByLocale } from "../data/navigation";
import type { Locale, LocaleLink } from "../data/site";

interface Props {
	footerTitle: string;
	footerCopy: string;
	footerMetaLabel: string;
	footerMetaValue: string;
	localeLinks: LocaleLink[];
	currentLocale: Locale;
}

const { footerTitle, footerCopy, footerMetaLabel, footerMetaValue, localeLinks, currentLocale } = Astro.props;
const linkGroups = footerLinkGroupsByLocale[currentLocale];
---

<footer class="site-footer">
	<div class="site-container site-footer-inner">
		<div class="site-footer-brand">
			<div class="site-footer-brand-row">
				<span class="site-footer-mark">C</span>
				<div>
					<p class="site-footer-title">{footerTitle}</p>
					<p class="site-footer-copy text-muted">{footerCopy}</p>
				</div>
			</div>
			<div class="site-footer-socials" aria-label="Social placeholders">
				<span>Telegram</span>
				<span>LinkedIn</span>
				<span>Instagram</span>
			</div>
		</div>
		<div class="site-footer-links">
			{linkGroups.map((group) => (
				<nav class="site-footer-group" aria-label={group.title}>
					<p class="type-label">{group.title}</p>
					<div class="site-footer-group-links">
						{group.links.map((link) => (
							<a href={link.href}>{link.label}</a>
						))}
					</div>
				</nav>
			))}
		</div>
		<div class="site-footer-meta">
			<div class="site-footer-meta-head">
				<p class="type-label">{footerMetaLabel}</p>
				<div class="site-footer-locale">
					<LocaleSwitcher
						localeLinks={localeLinks}
						currentLocale={currentLocale}
						label="Footer language switcher"
						mode="footer"
					/>
				</div>
			</div>
			<p class="text-muted">{footerMetaValue}</p>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		padding: 0 0 clamp(1.75rem, 3vw, var(--space-6));
	}

	.site-footer-inner {
		display: grid;
		grid-template-columns: minmax(0, 1.2fr) auto auto;
		align-items: start;
		gap: 0.9rem 2.1rem;
		padding-top: clamp(1.35rem, 2.3vw, var(--space-5));
		border-top: 1px solid rgba(113, 88, 62, 0.18);
	}

	.site-footer-title {
		margin-bottom: 0.35rem;
		font-weight: 700;
	}

	.site-footer-brand-row {
		display: flex;
		align-items: flex-start;
		gap: 0.85rem;
	}

	.site-footer-mark {
		display: inline-grid;
		place-items: center;
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 1rem;
		background: linear-gradient(145deg, var(--color-terracotta), var(--color-terracotta-active));
		color: var(--color-ivory);
		font-family: var(--font-display);
		font-weight: 700;
	}

	.site-footer-copy,
	.site-footer-meta p {
		margin-bottom: 0;
	}

	.site-footer-socials {
		display: flex;
		flex-wrap: wrap;
		gap: 0.55rem;
		margin-top: var(--space-3);
	}

	.site-footer-socials span {
		padding: 0.4rem 0.7rem;
		border: 1px solid var(--color-border-sand);
		border-radius: var(--radius-pill);
		background: var(--surface-card);
		color: var(--color-slate);
		font-family: var(--font-mono);
		font-size: var(--text-label);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.site-footer-links {
		display: flex;
		flex-wrap: wrap;
		align-items: flex-start;
		gap: 0.75rem 1.7rem;
	}

	.site-footer-group {
		display: grid;
		gap: 0.55rem;
		flex: 0 0 auto;
		min-width: 7.75rem;
	}

	.site-footer-group-links {
		display: grid;
		gap: 0.45rem;
	}

	.site-footer-group-links a {
		color: var(--color-slate);
		text-decoration: none;
		transition: color 160ms ease;
	}

	.site-footer-group-links a:hover {
		color: var(--color-ink);
	}

	.site-footer-meta {
		display: grid;
		gap: 0.5rem;
		text-align: right;
		width: min(100%, 19rem);
		justify-self: end;
	}

	.site-footer-meta-head {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.65rem;
		flex-wrap: nowrap;
	}

	.site-footer-locale {
		justify-self: end;
		flex: 0 0 auto;
	}

	:global([dir="rtl"]) .site-footer-brand {
		text-align: right;
	}

	:global([dir="rtl"]) .site-footer-brand-row {
		flex-direction: row-reverse;
	}

	:global([dir="rtl"]) .site-footer-meta {
		text-align: right;
	}

	:global([dir="rtl"]) .site-footer-meta-head {
		justify-content: flex-start;
	}

	@media (max-width: 720px) {
		.site-footer-inner {
			grid-template-columns: 1fr;
		}

		.site-footer-links {
			display: grid;
			grid-template-columns: 1fr;
			gap: 1rem;
		}

		.site-footer-meta {
			text-align: left;
			justify-self: start;
			width: min(100%, 22rem);
			gap: 0.75rem;
		}

		.site-footer-meta-head {
			justify-content: flex-start;
			flex-wrap: wrap;
		}

		.site-footer-locale {
			justify-self: start;
		}

		:global([dir="rtl"]) .site-footer-meta {
			text-align: right;
			justify-self: end;
		}

		:global([dir="rtl"]) .site-footer-locale {
			justify-self: end;
		}
	}
</style>
