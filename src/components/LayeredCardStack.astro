---
interface Card {
	label: string;
	title: string;
	meta: string;
	tone?: "terracotta" | "navy" | "success" | "warning";
}

interface Props {
	cards: Card[];
	autoRotate?: boolean;
}

const { cards, autoRotate = false } = Astro.props;
const rotations = ["-4deg", "-1.5deg", "2deg", "5deg"];
---

<div
	class="stack"
	aria-label="Operational card stack"
	data-card-stack
	data-auto-rotate={autoRotate ? "true" : "false"}
>
	{cards.map((card, index) => (
		<article
			class:list={[
				"stack-card",
				`tone-${card.tone ?? "terracotta"}`,
				index === cards.length - 1 && "is-active-card",
			]}
			style={`--stack-order:${cards.length - 1 - index}; --card-rotation:${rotations[index % rotations.length]}; --reveal-delay:${120 + index * 90}ms;`}
			data-stack-card
			data-stack-index={index}
			role="button"
			tabindex="0"
			aria-label={`${card.label}: ${card.title}`}
			aria-pressed={index === cards.length - 1 ? "true" : "false"}
		>
			<p class="stack-label type-label">{card.label}</p>
			<h3>{card.title}</h3>
			<p class="stack-meta">{card.meta}</p>
		</article>
	))}
</div>

<style>
	.stack {
		position: relative;
		display: flex;
		align-items: end;
		justify-content: end;
		width: 100%;
		flex: 1 1 auto;
		min-height: clamp(21.5rem, 29vw, 25.25rem);
		padding: clamp(0.55rem, 1vw, 0.85rem) 0 clamp(0.9rem, 1.4vw, 1.15rem);
		isolation: isolate;
		touch-action: pan-y;
		--stack-y-gap: 1.7rem;
		--stack-x-gap: 1rem;
		--stack-scale-step: 0.045;
		--stack-rest-opacity: 0.92;
		--stack-active-lift: 0.8rem;
	}

	.stack:hover,
	.stack:focus-within {
		--stack-y-gap: 2rem;
		--stack-x-gap: 1.14rem;
		--stack-active-lift: 0.96rem;
	}

	.stack-card {
		position: absolute;
		inset: auto clamp(0.35rem, 0.9vw, 0.8rem) clamp(1rem, 2vw, 1.45rem) auto;
		width: min(100%, 19.2rem);
		padding: 1rem 1rem 1.1rem;
		border-radius: 22px;
		border: 1px solid rgba(113, 88, 62, 0.16);
		background: rgba(255, 253, 249, 0.96);
		box-shadow: 0 12px 28px rgba(20, 32, 51, 0.08);
		backdrop-filter: blur(10px);
		cursor: pointer;
		user-select: none;
		-webkit-tap-highlight-color: transparent;
		--stack-scale: calc(1 - (var(--stack-order) * var(--stack-scale-step)));
		--stack-transform:
			translateY(calc(var(--stack-order) * var(--stack-y-gap) * -1))
			translateX(calc(var(--stack-order) * var(--stack-x-gap) * -1))
			scale(var(--stack-scale))
			rotate(calc(var(--card-rotation) + (var(--stack-order) * -0.35deg)));
		transform: var(--stack-transform);
		transform-origin: right bottom;
		z-index: calc(20 - var(--stack-order));
		opacity: var(--stack-rest-opacity);
		will-change: transform, opacity;
		transition:
			transform var(--motion-base) var(--motion-spring),
			box-shadow var(--motion-fast) ease,
			border-color var(--motion-fast) ease,
			opacity var(--motion-fast) ease;
	}

	.stack-card::before {
		content: "";
		position: absolute;
		inset: 0 0 auto 0;
		height: 1px;
		background: linear-gradient(90deg, transparent, rgba(201, 106, 58, 0.28), transparent);
		pointer-events: none;
	}

	.stack-card.is-active-card {
		--stack-transform:
			translateY(calc(var(--stack-order) * var(--stack-y-gap) * -1 - var(--stack-active-lift)))
			translateX(calc(var(--stack-order) * var(--stack-x-gap) * -1))
			scale(1)
			rotate(calc(var(--card-rotation) + (var(--stack-order) * -0.35deg)));
		border-color: rgba(113, 88, 62, 0.24);
		box-shadow: 0 24px 52px rgba(20, 32, 51, 0.14);
		opacity: 1;
	}

	.stack-card:focus-visible {
		outline: 2px solid rgba(201, 106, 58, 0.42);
		outline-offset: 4px;
	}

	.stack-label {
		margin-bottom: 0.68rem;
	}

	.stack-card h3 {
		font-size: var(--text-h3);
		margin-bottom: 0.55rem;
		max-width: 14ch;
		transition:
			color var(--motion-fast) ease,
			transform var(--motion-fast) ease;
	}

	.stack-meta {
		margin: 0;
		color: var(--color-slate);
		line-height: 1.6;
		max-width: 24ch;
		max-height: 5.5rem;
		overflow: hidden;
		transition:
			opacity var(--motion-fast) ease,
			max-height var(--motion-fast) ease,
			transform var(--motion-fast) ease;
	}

	.stack-card:not(.is-active-card) h3 {
		margin-bottom: 0;
		transform: translateY(0.08rem);
	}

	.stack-card:not(.is-active-card) .stack-meta {
		opacity: 0;
		max-height: 0;
		transform: translateY(-0.3rem);
		pointer-events: none;
	}

	:global([dir="rtl"]) .stack-card {
		right: auto;
		left: clamp(0.35rem, 0.9vw, 0.8rem);
		--stack-transform:
			translateY(calc(var(--stack-order) * var(--stack-y-gap) * -1))
			translateX(calc(var(--stack-order) * var(--stack-x-gap)))
			scale(var(--stack-scale))
			rotate(calc(var(--card-rotation) + (var(--stack-order) * 0.35deg)));
		transform-origin: left bottom;
	}

	:global([dir="rtl"]) .stack-card.is-active-card {
		--stack-transform:
			translateY(calc(var(--stack-order) * var(--stack-y-gap) * -1 - var(--stack-active-lift)))
			translateX(calc(var(--stack-order) * var(--stack-x-gap)))
			scale(1)
			rotate(calc(var(--card-rotation) + (var(--stack-order) * 0.35deg)));
	}

	.tone-terracotta {
		background:
			linear-gradient(180deg, rgba(201, 106, 58, 0.07), transparent 34%),
			rgba(255, 253, 249, 0.96);
	}

	.tone-navy {
		background:
			linear-gradient(180deg, rgba(40, 71, 102, 0.08), transparent 34%),
			rgba(255, 253, 249, 0.96);
	}

	.tone-success {
		background:
			linear-gradient(180deg, rgba(47, 138, 98, 0.08), transparent 34%),
			rgba(255, 253, 249, 0.96);
	}

	.tone-warning {
		background:
			linear-gradient(180deg, rgba(173, 106, 39, 0.08), transparent 34%),
			rgba(255, 253, 249, 0.96);
	}

	@media (max-width: 820px) {
		.stack {
			min-height: 17.75rem;
			--stack-y-gap: 1.2rem;
			--stack-x-gap: 0.58rem;
		}
	}

	@media (max-width: 640px) {
		.stack {
			min-height: 15.6rem;
			padding-bottom: 0.6rem;
			--stack-y-gap: 0.92rem;
			--stack-x-gap: 0.32rem;
			--stack-scale-step: 0.038;
			--stack-active-lift: 0.52rem;
		}

		.stack-card {
			inset: auto clamp(0.3rem, 0.9vw, 0.65rem) 0.8rem auto;
			width: min(100%, 15.75rem);
			padding: 0.92rem 0.92rem 0.98rem;
			--stack-transform:
				translateY(calc(var(--stack-order) * var(--stack-y-gap) * -1))
				translateX(calc(var(--stack-order) * var(--stack-x-gap) * -1))
				scale(var(--stack-scale))
				rotate(calc(var(--card-rotation) + (var(--stack-order) * -0.24deg)));
		}

		.stack-card.is-active-card {
			--stack-transform:
				translateY(calc(var(--stack-order) * var(--stack-y-gap) * -1 - var(--stack-active-lift)))
				translateX(calc(var(--stack-order) * var(--stack-x-gap) * -1))
				scale(1)
				rotate(calc(var(--card-rotation) + (var(--stack-order) * -0.24deg)));
		}

		:global([dir="rtl"]) .stack-card {
			--stack-transform:
				translateY(calc(var(--stack-order) * var(--stack-y-gap) * -1))
				translateX(calc(var(--stack-order) * var(--stack-x-gap)))
				scale(var(--stack-scale))
				rotate(calc(var(--card-rotation) + (var(--stack-order) * 0.24deg)));
		}

		:global([dir="rtl"]) .stack-card.is-active-card {
			--stack-transform:
				translateY(calc(var(--stack-order) * var(--stack-y-gap) * -1 - var(--stack-active-lift)))
				translateX(calc(var(--stack-order) * var(--stack-x-gap)))
				scale(1)
				rotate(calc(var(--card-rotation) + (var(--stack-order) * 0.24deg)));
		}

		.stack-card h3 {
			max-width: none;
		}
	}
</style>

<script is:inline>
	(() => {
		const setupStack = (stack) => {
			if (!(stack instanceof HTMLElement) || stack.dataset.stackReady === "true") return;
			stack.dataset.stackReady = "true";

			const cards = Array.from(stack.querySelectorAll("[data-stack-card]"));
			if (cards.length === 0) return;

			let activeIndex = cards.length - 1;
			let autoRotateId = null;
			const prefersReducedMotion =
				window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
			const autoRotateEnabled = stack.dataset.autoRotate === "true";

			const update = () => {
				cards.forEach((card, index) => {
					const order = (activeIndex - index + cards.length) % cards.length;
					const isActive = order === 0;
					card.style.setProperty("--stack-order", String(order));
					card.style.zIndex = String(20 - order);
					card.classList.toggle("is-active-card", isActive);
					card.setAttribute("aria-pressed", isActive ? "true" : "false");
				});
			};

			const showIndex = (nextIndex) => {
				activeIndex = (nextIndex + cards.length) % cards.length;
				update();
			};

			const showNext = () => showIndex(activeIndex + 1);
			const showPrevious = () => showIndex(activeIndex - 1);

			const stopAutoRotate = () => {
				if (autoRotateId !== null) {
					window.clearInterval(autoRotateId);
					autoRotateId = null;
				}
			};

			const startAutoRotate = () => {
				if (!autoRotateEnabled || prefersReducedMotion || cards.length < 2 || autoRotateId !== null) return;
				autoRotateId = window.setInterval(showNext, 7600);
			};

			const resetAutoRotate = () => {
				stopAutoRotate();
				startAutoRotate();
			};

			cards.forEach((card, index) => {
				card.addEventListener("click", () => {
					if (index === activeIndex) {
						showNext();
					} else {
						showIndex(index);
					}
					resetAutoRotate();
				});

				card.addEventListener("keydown", (event) => {
					if (!(event instanceof KeyboardEvent)) return;

					if (event.key === "ArrowRight" || event.key === "ArrowDown") {
						event.preventDefault();
						showNext();
						resetAutoRotate();
						return;
					}

					if (event.key === "ArrowLeft" || event.key === "ArrowUp") {
						event.preventDefault();
						showPrevious();
						resetAutoRotate();
						return;
					}

					if (event.key === "Enter" || event.key === " ") {
						event.preventDefault();
						if (index === activeIndex) {
							showNext();
						} else {
							showIndex(index);
						}
						resetAutoRotate();
					}
				});
			});

			stack.addEventListener("pointerenter", stopAutoRotate);
			stack.addEventListener("pointerleave", startAutoRotate);
			stack.addEventListener("focusin", stopAutoRotate);
			stack.addEventListener("focusout", () => {
				window.setTimeout(() => {
					if (!stack.contains(document.activeElement)) {
						startAutoRotate();
					}
				}, 0);
			});
			document.addEventListener("visibilitychange", () => {
				if (document.hidden) {
					stopAutoRotate();
				} else {
					startAutoRotate();
				}
			});

			update();
			startAutoRotate();
		};

		const init = () => {
			document.querySelectorAll("[data-card-stack]").forEach(setupStack);
		};

		if (document.readyState === "loading") {
			document.addEventListener("DOMContentLoaded", init, { once: true });
		} else {
			init();
		}
	})();
</script>
